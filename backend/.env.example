# MongoDB (Railway fornece automaticamente se você adicionar o plugin MongoDB)
MONGO_URL=mongodb://mongo:SUA_SENHA@mongodb.railway.internal:27017
DB_NAME=betops

# JWT — gere uma chave segura: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=TROQUE_POR_UMA_CHAVE_SECRETA_FORTE
JWT_ALGORITHM=HS256

# CORS — coloque a URL do seu frontend na Vercel
# Exemplo: https://betops.vercel.app
CORS_ORIGINS=https://SEU-FRONTEND.vercel.app
